{
  "compilerOptions": {
    "target":                      "ES2020",
    "module":                      "ESNext",
    "moduleResolution":            "bundler",
    "strict":                      true,
    "exactOptionalPropertyTypes":  true,
    "noUncheckedIndexedAccess":    true,
    "noImplicitReturns":           true,
    "noFallthroughCasesInSwitch":  true,
    "esModuleInterop":             true,
    "skipLibCheck":                true,
    "declaration":                 true,
    "declarationMap":              true,
    "sourceMap":                   true
  }
}
