{
  "name": "figura",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "lint": "eslint packages/*/src packages/*/tests --ext .ts",
    "lint:unused": "knip",
    "lint:deps": "depcheck",
    "lint:mono": "sherif",
    "lint:spelling": "cspell 'packages/*/src/**/*.ts' 'packages/*/tests/**/*.ts'",
    "lint:exports": "publint packages/core && publint packages/strudel",
    "lint:all": "pnpm lint && pnpm lint:unused && pnpm lint:deps && pnpm lint:mono && pnpm lint:spelling && pnpm lint:exports",
    "format": "prettier --write packages/*/src packages/*/tests",
    "typecheck": "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "cspell": "^9.7.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "sherif": "^1.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@strudel/web": "^1.3.0"
  }
}
